{
	"compilerOptions": {
	"target": "ES2022",
	"module": "CommonJS",
	"lib": ["ES2022"],
	"outDir": "./out",
	"rootDir": "./src",
	"strict": true,
	"esModuleInterop": true,
	"skipLibCheck": true,
	"forceConsistentCasingInFileNames": true,
	"moduleResolution": "node",
	"paths": {
		"@codix/sdk": ["../../../packages/sdk-ts/src/index"]
	},
	"types": ["node"]
	},
	"include": ["src/**/*"]
}
